# Copy to .env and adjust. Local DB matches docker-compose.yml in repo root.
#
# Python: `pip install -r requirements.txt` (prod deps). Optional full dev: `requirements-dev.txt`
#
DATABASE_URL=postgresql+asyncpg://clinic:clinic@localhost:5432/clinic_db

# Optional: OCR + LLM (see server.py)
# EMERGENT_LLM_KEY=
# TESSERACT_PSM=6

# OpenAI Vision — scan reads the SHEET IMAGE and builds the appointment table (strongly recommended).
# Without OPENAI_API_KEY, only Tesseract + heuristics run; messy photos may export as raw OCR only.
# OPENAI_API_KEY=sk-...
# Default model is gpt-4o (best table accuracy). Use gpt-4o-mini to reduce cost.
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_DETAIL=high
# OPENAI_IMAGE_MAX_SIDE=3072
# OPENAI_IMAGE_MIN_UPSCALE=2000
# OPENAI_JPEG_QUALITY=92
