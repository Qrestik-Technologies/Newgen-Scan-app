# Python: `pip install -r requirements.txt` is production-only; full dev deps: `requirements-dev.txt`
#
# PostgreSQL — local (docker-compose) or Supabase (see Railway deploy notes).
# Supabase: Settings → Database → URI. Replace postgresql:// with postgresql+asyncpg:// and append ?ssl=require
# Example: postgresql+asyncpg://postgres.xxxx:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://clinic:clinic@localhost:5432/clinic_db

# Optional: OCR + LLM (see server.py)
# EMERGENT_LLM_KEY=
# Tesseract page segmentation: 6 = uniform block (default); try 4 or 11 if tables OCR poorly
# TESSERACT_PSM=6

# OpenAI Vision: reads the appointment sheet image; exports use the table when rows exist.
# OPENAI_API_KEY=sk-...
# Default model is gpt-4o (best table accuracy). Use gpt-4o-mini to reduce cost.
# OPENAI_VISION_MODEL=gpt-4o
# Image sent to API: high detail uses more tokens but reads small handwriting better.
# OPENAI_IMAGE_DETAIL=high
# OPENAI_IMAGE_MAX_SIDE=3072
# OPENAI_IMAGE_MIN_UPSCALE=2000
# OPENAI_JPEG_QUALITY=92
